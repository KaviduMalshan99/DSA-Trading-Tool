# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dsa_trading
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dsa_trading

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Binance ────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ── Forex (Alpha Vantage) ──────────────────────────────────────────────────────
FOREX_API_KEY=your_alphavantage_key

# ── Stocks (Polygon.io) ────────────────────────────────────────────────────────
STOCKS_API_KEY=your_polygon_key

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000
